---
import Layout from '../layouts/Layout.astro';

const posts = await Astro.glob('../content/posts/*.mdx');
const publishedPosts = posts
  .filter((post) => !post.frontmatter.draft)
  .sort((a, b) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime());
---

<Layout title="Blog - Canopy">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-8 text-[#00D4FF]">Blog</h1>
    
    {publishedPosts.length === 0 ? (
      <div class="text-center py-20">
        <p class="text-white/60 text-lg">No posts yet. Check back soon!</p>
      </div>
    ) : (
      <div class="space-y-8">
        {publishedPosts.map((post) => (
          <article class="p-6 rounded-xl bg-white/5 border border-white/10 hover:border-[#00D4FF]/50 transition">
            {post.frontmatter.heroImage && (
              <img 
                src={post.frontmatter.heroImage} 
                alt={post.frontmatter.title}
                class="w-full h-48 object-cover rounded-lg mb-4"
              />
            )}
            <h2 class="text-2xl font-semibold mb-2">
              <a href={`/blog/${post.frontmatter.slug || post.file.split('/').pop().replace('.mdx', '')}`} class="hover:text-[#00D4FF] transition">
                {post.frontmatter.title}
              </a>
            </h2>
            <p class="text-white/60 mb-3">{post.frontmatter.description}</p>
            <div class="flex items-center gap-4 text-sm text-white/40">
              <time datetime={post.frontmatter.pubDate}>
                {new Date(post.frontmatter.pubDate).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              {post.frontmatter.tags && (
                <div class="flex gap-2">
                  {post.frontmatter.tags.map((tag: string) => (
                    <span class="px-2 py-1 bg-[#00D4FF]/10 rounded text-[#00D4FF]">{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</Layout>