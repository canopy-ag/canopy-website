# Environment Variables for Canopy Website
# Copy to .env.local for local development

# ===========================================
# DATABASE
# ===========================================

# PostgreSQL Connection String (via Tailscale or direct)
# For production (via Tailscale Funnel):
POSTGRES_URL=postgresql://canopy_website_user:yourpassword@canopy-dev-db.your-tailnet.ts.net:5432/canopy_website

# For local development (direct to LoadBalancer):
# POSTGRES_URL=postgresql://canopy_website_user:yourpassword@192.168.1.190:5432/canopy_website?sslmode=disable

# Connection Pool Settings (optional, defaults to 10)
DATABASE_MAX_CONNECTIONS=10

# ===========================================
# BOT PROTECTION
# ===========================================

# Cloudflare Turnstile (CAPTCHA)
# Get your keys from: https://dash.cloudflare.com/ → Turnstile
# Public key (exposed to client, prefix with PUBLIC_)
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Secret key (server-side only, NEVER commit real key)
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Testing keys (shown above) always pass validation
# Production keys from Cloudflare will actually verify users

# ===========================================
# EMAIL NOTIFICATIONS
# ===========================================

# Resend API for email notifications (optional, fallback when DB fails)
# Get your key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# ===========================================
# BRANDING
# ===========================================

# Logo variant selection: hex (default) or leafy
PUBLIC_LOGO_VARIANT=hex
