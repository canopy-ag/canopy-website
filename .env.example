# Database Environment Variables
# Copy to .env.local for local development

# PostgreSQL Connection String
# For local development (direct to LoadBalancer):
DATABASE_URL=postgresql://canopy_website_user:yourpassword@192.168.1.190:5432/canopy_website?sslmode=disable

# For production (via Tailscale Funnel):
# DATABASE_URL=postgresql://canopy_website_user:yourpassword@canopy-dev-db.your-tailnet.ts.net:5432/canopy_website?sslmode=require

# Connection Pool Settings
DATABASE_MAX_CONNECTIONS=5

# Optional: Email notifications via Resend
# RESEND_API_KEY=re_xxxxxxxx

# Optional: Webhook notifications
# HOME_LAB_WEBHOOK_URL=https://hooks.slack.com/services/...
